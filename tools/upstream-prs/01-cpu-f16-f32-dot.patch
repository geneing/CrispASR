From: <author>
Subject: [PATCH] ggml-cpu : F16 mul_mat input saturation on ARM NEON

Upstream `mul_mat` for F16 weights x F32 inputs first converts
`src1` (F32) to F16 via `__fp16` cast, saturating values above 65504
to +-Inf. The Inf propagates through the dot product and the next
layer's RMSNorm produces NaN, even with an F32 accumulator. Affects
any model whose intermediate activations exceed 65504 -- common in
FFN `silu(gate) * up` products for hidden sizes >= ~3072 (a 3072-
wide block can reach ~1.4e5 even when individual mul_mat outputs
are 200-400 in magnitude).

Q8_0 vec_dot is unaffected because its inner loop keeps src1 as
F32. Apple Metal matmul kernels also accumulate in F32 and are
unaffected.

Add `ggml_vec_dot_f16_f32` (F16 weight x F32 input -> F32 sum,
NEON + AVX2/F16C + scalar) and route F16 type traits through it
with `vec_dot_type = F32`. `ggml_compute_forward_mul_mat` then
sees src1 already matches vec_dot_type and skips the saturating
F32 -> F16 quantize step.

Defence-in-depth: switch `ggml_vec_dot_f16` (still called by
`conv_transpose_1d_f16` etc. outside the type-traits dispatch)
from `vfmaq_f16` to F32 accumulator via `simd-mappings.h` -- the
F16 register accumulator can also overflow on long F16xF16 dot
products.

diff --git a/ggml/src/ggml-cpu/ggml-cpu.c b/ggml/src/ggml-cpu/ggml-cpu.c
--- a/ggml/src/ggml-cpu/ggml-cpu.c
+++ b/ggml/src/ggml-cpu/ggml-cpu.c
@@ -212,9 +212,9 @@ static const struct ggml_type_traits_cpu type_traits_cpu[GGML_TYPE_COUNT] = {
         .nrows                    = 1,
     },
     [GGML_TYPE_F16] = {
         .from_float               = (ggml_from_float_t) ggml_cpu_fp32_to_fp16,
-        .vec_dot                  = (ggml_vec_dot_t) ggml_vec_dot_f16,
-        .vec_dot_type             = GGML_TYPE_F16,
+        .vec_dot                  = (ggml_vec_dot_t) ggml_vec_dot_f16_f32,
+        .vec_dot_type             = GGML_TYPE_F32,
         .nrows                    = 1,
     },
     [GGML_TYPE_Q1_0] = {
diff --git a/ggml/src/ggml-cpu/simd-mappings.h b/ggml/src/ggml-cpu/simd-mappings.h
--- a/ggml/src/ggml-cpu/simd-mappings.h
+++ b/ggml/src/ggml-cpu/simd-mappings.h
@@ -246,7 +246,7 @@ inline static float ggml_lookup_fp16_to_fp32(ggml_fp16_t f) {

 // F16 NEON

-#if defined(__ARM_FEATURE_FP16_VECTOR_ARITHMETIC)
+#if 0 && defined(__ARM_FEATURE_FP16_VECTOR_ARITHMETIC)  /* force F32 accumulator */
     #define GGML_F16_STEP 32
     #define GGML_F16_EPR  8

@@ -288,8 +288,7 @@ inline static float ggml_lookup_fp16_to_fp32(ggml_fp16_t f) {
     #define GGML_F16_VEC_MUL            GGML_F16x8_MUL
     #define GGML_F16_VEC_REDUCE         GGML_F16x8_REDUCE
 #else
-    // if FP16 vector arithmetic is not supported, we use FP32 instead
-    // and take advantage of the vcvt_ functions to convert to/from FP16
+    // F16 in memory, F32 accumulator (vcvt_f32_f16 on load, vfmaq_f32 inner).

     #define GGML_F16_STEP 16
     #define GGML_F16_EPR  4
@@ -362,7 +361,7 @@ inline static float ggml_lookup_fp16_to_fp32(ggml_fp16_t f) {

 // F16 NEON

-#if defined(__ARM_FEATURE_FP16_VECTOR_ARITHMETIC)
+#if 0 && defined(__ARM_FEATURE_FP16_VECTOR_ARITHMETIC)  /* force F32 accumulator */
     #define GGML_F16_STEP 32
     #define GGML_F16_EPR  8

@@ -403,8 +402,7 @@ inline static float ggml_lookup_fp16_to_fp32(ggml_fp16_t f) {
     #define GGML_F16_VEC_MUL            GGML_F16x8_MUL
     #define GGML_F16_VEC_REDUCE         GGML_F16x8_REDUCE
 #else
-    // if FP16 vector arithmetic is not supported, we use FP32 instead
-    // and take advantage of the vcvt_ functions to convert to/from FP16
+    // F16 in memory, F32 accumulator (vcvt_f32_f16 on load, vfmaq_f32 inner).

     #define GGML_F16_STEP 16
     #define GGML_F16_EPR  4
diff --git a/ggml/src/ggml-cpu/vec.cpp b/ggml/src/ggml-cpu/vec.cpp
--- a/ggml/src/ggml-cpu/vec.cpp
+++ b/ggml/src/ggml-cpu/vec.cpp
@@ -393,6 +393,55 @@ void ggml_vec_dot_f16(int n, float * GGML_RESTRICT s, size_t bs, ggml_fp16_t * G
     *s = sumf;
 }

+// F16 weight x F32 input -> F32 dot. Used by MUL_MAT when src0 is F16
+// and src1 is F32; vec_dot_type for F16 is set to F32 so the dispatch
+// reaches this path without an intermediate F32 -> F16 quantize that
+// would saturate values above 65504.
+void ggml_vec_dot_f16_f32(int n, float * GGML_RESTRICT s, size_t bs, ggml_fp16_t * GGML_RESTRICT x, size_t bx, float * GGML_RESTRICT y, size_t by, int nrc) {
+    assert(nrc == 1);
+    GGML_UNUSED(nrc);
+    GGML_UNUSED(bx);
+    GGML_UNUSED(by);
+    GGML_UNUSED(bs);
+
+    ggml_float sumf = 0.0;
+
+#if defined(__ARM_NEON) && defined(__ARM_FEATURE_FMA)
+    const int np = n & ~7;
+    float32x4_t s0 = vdupq_n_f32(0.0f);
+    float32x4_t s1 = vdupq_n_f32(0.0f);
+    for (int i = 0; i < np; i += 8) {
+        float32x4_t xa = vcvt_f32_f16(vld1_f16((const __fp16 *)(x + i)));
+        float32x4_t xb = vcvt_f32_f16(vld1_f16((const __fp16 *)(x + i + 4)));
+        float32x4_t ya = vld1q_f32(y + i);
+        float32x4_t yb = vld1q_f32(y + i + 4);
+        s0 = vfmaq_f32(s0, xa, ya);
+        s1 = vfmaq_f32(s1, xb, yb);
+    }
+    sumf = (ggml_float)(vaddvq_f32(s0) + vaddvq_f32(s1));
+    for (int i = np; i < n; ++i) {
+        sumf += (ggml_float)(GGML_CPU_FP16_TO_FP32(x[i]) * y[i]);
+    }
+#elif defined(__AVX2__) && defined(__F16C__)
+    const int np = n & ~7;
+    __m256 acc = _mm256_setzero_ps();
+    for (int i = 0; i < np; i += 8) {
+        __m256 xv = _mm256_cvtph_ps(_mm_loadu_si128((const __m128i *)(x + i)));
+        __m256 yv = _mm256_loadu_ps(y + i);
+        acc = _mm256_fmadd_ps(xv, yv, acc);
+    }
+    float buf[8];
+    _mm256_storeu_ps(buf, acc);
+    sumf = buf[0]+buf[1]+buf[2]+buf[3]+buf[4]+buf[5]+buf[6]+buf[7];
+    for (int i = np; i < n; ++i) {
+        sumf += (ggml_float)(GGML_CPU_FP16_TO_FP32(x[i]) * y[i]);
+    }
+#else
+    for (int i = 0; i < n; ++i) {
+        sumf += (ggml_float)(GGML_CPU_FP16_TO_FP32(x[i]) * y[i]);
+    }
+#endif
+
+    *s = sumf;
+}
+
 void ggml_vec_silu_f32(const int n, float * y, const float * x) {
     int i = 0;
 #if defined(__AVX512F__) && defined(__AVX512DQ__)
diff --git a/ggml/src/ggml-cpu/vec.h b/ggml/src/ggml-cpu/vec.h
--- a/ggml/src/ggml-cpu/vec.h
+++ b/ggml/src/ggml-cpu/vec.h
@@ -42,6 +42,7 @@ extern ggml_fp16_t ggml_table_gelu_quick_f16[1 << 16];
